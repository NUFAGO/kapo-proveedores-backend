# Kapo-Proveedores Backend — plantilla .env (copiar a .env)

NODE_ENV=development
PORT=8086

# --- Mongo ---
DATABASE_URL_DEV=mongodb://127.0.0.1:27017/proveedores_dev

# --- Tokens M2M (BL-OPS-002) — pares alineados entre microservicios ---
# | Par                    | Iniciador    | Variable Proveedores        | Variable peer              |
# | Pagos ↔ Proveedores    | Pagos        | PROVEEDORES_SERVICE_TOKEN   | PROVEEDORES_SERVICE_TOKEN  |
# | Proveedores ↔ Compras  | Proveedores  | COMPRAS_SERVICE_TOKEN       | COMPRAS_SERVICE_TOKEN      |
# Smoke cross-ref: Kapo-Pagos npm run verify:m2m-tokens

# --- Integración M2M ---
# Pagos INICIA (expediente/vínculo) → receptor valida este token
# DEBE coincidir con PROVEEDORES_SERVICE_TOKEN en Kapo-Pagos
PROVEEDORES_SERVICE_TOKEN=dev-proveedores-m2m-cambiar-en-equipo

# --- Kapo-Compras (source of truth OC list + tiene_expediente) ---
KAPO_COMPRAS_BACKEND_URL=http://localhost:8083/graphql
# Proveedores INICIA (actualizarTieneExpediente) → Compras valida COMPRAS_SERVICE_TOKEN
COMPRAS_SERVICE_TOKEN=dev-compras-m2m-cambiar-en-equipo

# --- Monolito (legacy puntual; OC list ya va a Compras) ---
INACONS_BACKEND_URL=http://localhost:8080/graphql
